; Engine configuration file.
; Godot 4.x project configuration.

[application]
config/name="Orbit Survivor"
config/version="0.1.0"
config/features=PackedStringArray("4.5")
run/main_scene="res://scenes/ui/main_menu.tscn"

[display]
window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="portrait"

[input_devices]
pointing/emulate_touch_from_mouse=true

[autoload]
SignalBus="*res://scripts/core/signals.gd"
Globals="*res://scripts/core/globals.gd"
GameManager="*res://scripts/managers/game_manager.gd"
LevelManager="*res://scripts/managers/level_manager.gd"
SaveManager="*res://scripts/managers/save_manager.gd"
AudioManager="*res://scripts/managers/audio_manager.gd"
StarSystem="*res://scripts/managers/star_system.gd"
DifficultyManager="*res://scripts/managers/difficulty_manager.gd"

[rendering]
quality/intended_usage/framebuffer_allocation=1
textures/vram_compression/import_etc2=true

[input]
ui_cancel={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194305,"physical_keycode":0,"key_label":0,"unicode":0,"echo":false,"script":null)
]
}

[debug]
gdscript/warnings/inference_on_variant=0
gdscript/warnings/return_value_discarded=0
gdscript/warnings/unused_signal=0
gdscript/warnings/unused_parameter=0
gdscript/warnings/unused_local_variable=0
